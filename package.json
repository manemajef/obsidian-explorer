{
	"name": "obsidian-explorer",
	"version": "1.3.1",
	"description": "A file explorer view for Obsidian",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"lint:css": "stylelint \"src/ui/styles/**/*.css\"",
		"lint": "npx eslint ."
	},
	"keywords": [
		"obsidian",
		"plugin",
		"explorer"
	],
	"author": "Rotem Semah",
	"license": "MIT",
	"dependencies": {
		"react": "^18.2.0",
		"react-dom": "^18.2.0"
	},
	"devDependencies": {
		"@eslint/json": "0.14.0",
		"@types/node": "^16.11.6",
		"@types/react": "^18.2.43",
		"@types/react-dom": "^18.2.17",
		"@typescript-eslint/parser": "^8.54.0",
		"esbuild": "0.17.3",
		"eslint": "^9.39.2",
		"eslint-plugin-obsidianmd": "^0.1.9",
		"obsidian": "latest",
		"stylelint": "^17.12.0",
		"stylelint-config-standard": "^40.0.0",
		"tslib": "2.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0"
	}
}
