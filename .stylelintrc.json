{
  "extends": [
    "stylelint-config-standard"
  ],
  "rules": {
    "no-descending-specificity": null,
    "selector-class-pattern": null,
    "custom-property-pattern": null,
    "alpha-value-notation": null,
    "color-function-notation": null,
    "color-function-alias-notation": null,
    "color-hex-length": null,
    "property-no-vendor-prefix": null,
    "comment-empty-line-before": null,
    "rule-empty-line-before": null,
    "custom-property-empty-line-before": null,
    "declaration-empty-line-before": null,
    "import-notation": null,
    "shorthand-property-no-redundant-values": null,
    "declaration-property-value-keyword-no-deprecated": null,
    "declaration-block-no-redundant-longhand-properties": null,
    "no-duplicate-selectors": true,
    "declaration-block-no-duplicate-properties": [
      true,
      {
        "ignore": [
          "consecutive-duplicates-with-different-values"
        ]
      }
    ],
    "selector-disallowed-list": [
      [
        "/\\.theme-(dark|light)/",
        "/\\.is-(mobile|phone|tablet)/"
      ],
      {
        "message": "Theme/platform selectors live only in tokens.css (value resolution) and fixes/ (documented hacks). See STYLING.md."
      }
    ],
    "selector-max-class": 4,
    "selector-max-compound-selectors": 4,
    "selector-max-specificity": "0,5,1",
    "declaration-property-value-disallowed-list": [
      {
        "/^--explorer-text-/": ["/.+/"]
      },
      {
        "message": "Type tokens (--explorer-text-*) may only be assigned in tokens.css (defaults) and primitives/text.css (density tiers). Components select a role/density; they never redefine type tokens. See STYLING.md."
      }
    ]
  },
  "ignoreFiles": [
    "styles.css",
    "node_modules/**",
    "main.js"
  ],
  "overrides": [
    {
      "files": [
        "**/tokens.css",
        "**/fixes/*.css"
      ],
      "rules": {
        "selector-disallowed-list": null,
        "selector-max-class": null,
        "selector-max-compound-selectors": null,
        "selector-max-specificity": null,
        "declaration-property-value-disallowed-list": null
      }
    },
    {
      "files": [
        "**/primitives/text.css"
      ],
      "rules": {
        "declaration-property-value-disallowed-list": null
      }
    },
    {
      "files": [
        "**/host.css"
      ],
      "rules": {
        "selector-max-class": null
      }
    }
  ]
}